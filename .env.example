# Multi-device sync (Supabase). Copy this file to `.env.local` and fill in the
# values from your Supabase project (Project Settings -> API). Leaving these
# unset simply disables sync — the app still works fully offline/local.
#
# The anon key is safe to ship in the client bundle: Row Level Security (see
# supabase/schema.sql) scopes every row to the signed-in user.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
